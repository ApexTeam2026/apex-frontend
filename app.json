{
  "expo": {
    "name": "/Пермь",
    "slug": "perm-discovery-map",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./src/assets/images/icon.png",
    "scheme": "permdiscoverymap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.permdiscovery.map",

      "usesCleartextTraffic": true,

      "icon": "./src/assets/images/icon.png",

      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "API_URL": "http://153.80.245.172:8081",
      "router": {},
      "eas": {
        "projectId": "eb4caea9-21ab-4db8-8b7d-b8b67fbb7fbb"
      }
    }
  }
}
